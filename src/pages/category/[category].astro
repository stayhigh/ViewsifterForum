---
import Layout from "../../layouts/Layout.astro";
import { getTopicsByCategory, getExcerpt } from "../../lib/data";
import { CATEGORY_META } from "../../lib/types";
import type { Category } from "../../lib/types";

const { category } = Astro.params;
const catKey = category!.toUpperCase() as Category;

if (!CATEGORY_META[catKey]) {
  return new Response("Not Found", { status: 404 });
}

const meta = CATEGORY_META[catKey];
const env = (Astro.locals as any).runtime?.env;
const topics = await getTopicsByCategory(catKey, env);
---

<Layout>
  <main class="container">
    <header class="page-header">
      <a href="/" class="back-link">← 返回首頁</a>
      <h1 class="page-title">
        <span class="cat-icon">{meta.icon}</span>
        {meta.name}
      </h1>
      <p class="page-desc">{meta.desc}</p>
    </header>

    <div class="topic-list">
      {
        topics.length === 0 ? (
          <p class="empty">— 尚無討論 —</p>
        ) : (
          topics.map((topic) => (
            <article class="topic-card">
              <a href={`/topic/${topic.slug}`} class="topic-link">
                <h2 class="topic-title">{topic.title}</h2>
                <p class="topic-excerpt">{getExcerpt(topic.content)}</p>
                <div class="topic-meta">
                  <time datetime={topic.created_at}>
                    {new Date(topic.created_at).toLocaleDateString("zh-TW", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                      timeZone: "UTC",
                    })}
                  </time>
                </div>
              </a>
            </article>
          ))
        )
      }
    </div>
  </main>
</Layout>

<style>
  .page-header {
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .page-title {
    font-size: 1.75rem;
    font-weight: 400;
    letter-spacing: 0.08em;
    color: var(--color-ink);
  }

  .cat-icon {
    margin-right: 0.5rem;
    font-size: 1.5rem;
  }

  .page-desc {
    margin-top: 0.5rem;
    color: var(--color-muted);
    font-size: 0.95rem;
  }

  .topic-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .topic-card {
    border-bottom: 1px solid var(--color-border);
  }

  .topic-link {
    display: block;
    padding: 1.75rem 0;
    border-bottom: none;
  }

  .topic-link:hover {
    border-bottom: none;
  }

  .topic-link:hover .topic-title {
    color: var(--color-earth);
  }

  .topic-title {
    font-size: 1.15rem;
    font-weight: 400;
    color: var(--color-ink);
    margin-bottom: 0.5rem;
    letter-spacing: 0.03em;
    transition: color 0.2s ease;
  }

  .topic-excerpt {
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .topic-meta {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  .empty {
    text-align: center;
    color: var(--color-muted);
    padding: 3rem 0;
    font-size: 0.95rem;
  }
</style>
