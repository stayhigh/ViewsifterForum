---
import Layout from "../layouts/Layout.astro";
import { getAllTopics, getExcerpt } from "../lib/data";
import { CATEGORY_META } from "../lib/types";

const env = (Astro.locals as any).runtime?.env;
const topics = await getAllTopics(env);
const recent = topics.slice(0, 6);
---

<Layout>
  <main class="container">
    <header class="hero">
      <h1 class="hero-title">ViewsForum</h1>
      <p class="hero-subtitle">深度對話 · 思想淬煉</p>
    </header>

    <nav class="categories">
      <a href="/category/ai" class="category-card">
        <span class="category-icon">{CATEGORY_META.AI.icon}</span>
        <span class="category-name">{CATEGORY_META.AI.name}</span>
        <span class="category-desc">{CATEGORY_META.AI.desc}</span>
      </a>
      <a href="/category/fin" class="category-card">
        <span class="category-icon">{CATEGORY_META.FIN.icon}</span>
        <span class="category-name">{CATEGORY_META.FIN.name}</span>
        <span class="category-desc">{CATEGORY_META.FIN.desc}</span>
      </a>
      <a href="/category/life" class="category-card">
        <span class="category-icon">{CATEGORY_META.LIFE.icon}</span>
        <span class="category-name">{CATEGORY_META.LIFE.name}</span>
        <span class="category-desc">{CATEGORY_META.LIFE.desc}</span>
      </a>
    </nav>

    <section class="feed">
      <h2 class="feed-title">最新討論</h2>
      {
        recent.map((topic) => (
          <article class="topic-card">
            <a href={`/topic/${topic.slug}`} class="topic-link">
              <span class="topic-cat">{CATEGORY_META[topic.category].icon} {CATEGORY_META[topic.category].name}</span>
              <h3 class="topic-title">{topic.title}</h3>
              <p class="topic-excerpt">{getExcerpt(topic.content)}</p>
            </a>
          </article>
        ))
      }
      <p class="feed-footer">— 共 {topics.length} 篇討論 —</p>
    </section>
  </main>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 5rem 0 4rem;
  }

  .hero-title {
    font-size: 2rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    color: var(--color-ink);
  }

  .hero-subtitle {
    margin-top: 0.75rem;
    font-size: 1rem;
    color: var(--color-muted);
    letter-spacing: 0.08em;
  }

  .categories {
    display: flex;
    gap: 1.25rem;
    margin-bottom: 4rem;
    flex-wrap: wrap;
  }

  .category-card {
    flex: 1;
    min-width: 180px;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: transparent;
    transition: border-color 0.2s ease;
    border-bottom: 1px solid var(--color-border);
  }

  .category-card:hover {
    border-color: var(--color-earth);
    border-bottom: 1px solid var(--color-earth);
  }

  .category-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
  }

  .category-name {
    font-size: 1.05rem;
    color: var(--color-ink);
    margin-bottom: 0.35rem;
    letter-spacing: 0.05em;
  }

  .category-desc {
    font-size: 0.8rem;
    color: var(--color-muted);
    text-align: center;
  }

  .feed {
    border-top: 1px solid var(--color-border);
    padding-top: 2.5rem;
  }

  .feed-title {
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
    letter-spacing: 0.05em;
  }

  .topic-card {
    border-bottom: 1px solid var(--color-border);
  }

  .topic-link {
    display: block;
    padding: 1.5rem 0;
    border-bottom: none;
  }

  .topic-link:hover {
    border-bottom: none;
  }

  .topic-link:hover .topic-title {
    color: var(--color-earth);
  }

  .topic-cat {
    font-size: 0.75rem;
    color: var(--color-earth);
    letter-spacing: 0.05em;
  }

  .topic-title {
    font-size: 1.05rem;
    font-weight: 400;
    color: var(--color-ink);
    margin: 0.35rem 0 0.4rem;
    letter-spacing: 0.03em;
    transition: color 0.2s ease;
  }

  .topic-excerpt {
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.7;
  }

  .feed-footer {
    text-align: center;
    color: var(--color-muted);
    padding: 2rem 0 0;
    font-size: 0.85rem;
  }

  @media (max-width: 640px) {
    .hero { padding: 3rem 0 2.5rem; }
    .hero-title { font-size: 1.5rem; }
    .categories { flex-direction: column; }
  }
</style>
