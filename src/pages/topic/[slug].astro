---
import Layout from "../../layouts/Layout.astro";
import { getTopicBySlug, getCommentsByTopicId, renderMarkdown } from "../../lib/data";
import { CATEGORY_META } from "../../lib/types";
import type { Category } from "../../lib/types";

const { slug } = Astro.params;
const env = (Astro.locals as any).runtime?.env;
const topic = await getTopicBySlug(slug!, env);

if (!topic) {
  return new Response("Not Found", { status: 404 });
}

const meta = CATEGORY_META[topic.category];
const catKey = topic.category.toLowerCase();

// Fetch comments (use topic.id to get comments)
const comments = await getCommentsByTopicId(Number(topic.id), env);

// Check if user is logged in
const userCookie = Astro.cookies.get("user_info")?.value;
const isLoggedIn = !!userCookie;
---

<Layout>
  <main class="container">
    <header class="article-header">
      <a href={`/category/${catKey}`} class="back-link">
        ← {meta.icon} {meta.name}
      </a>
      <h1 class="article-title">{topic.title}</h1>
      <div class="article-meta">
        <time datetime={topic.created_at}>
          {new Date(topic.created_at).toLocaleDateString("zh-TW", {
            year: "numeric",
            month: "long",
            day: "numeric",
            timeZone: "UTC",
          })}
        </time>
        {topic.user_name && <span class="author">— {topic.user_name}</span>}
      </div>
    </header>

    <article class="article-body">
      <Fragment set:html={renderMarkdown(topic.content)} />
    </article>

    <section class="comments-section">
      <h2 class="comments-title">討論 ({comments.length})</h2>
      
      {comments.length === 0 && (
        <p class="comments-empty">— 尚無回覆，登入後參與討論 —</p>
      )}

      {comments.map((c) => (
        <div class="comment">
          <div class="comment-meta">
            <span class="comment-author">{c.user_name}</span>
            <time datetime={c.created_at}>
              {new Date(c.created_at).toLocaleDateString("zh-TW", {
                year: "numeric",
                month: "long",
                day: "numeric",
                hour: "2-digit",
                minute: "2-digit",
                timeZone: "UTC",
              })}
            </time>
          </div>
          <div class="comment-body" set:html={renderMarkdown(c.content)} />
        </div>
      ))}

      {isLoggedIn ? (
        <form action="/api/comments" method="POST" class="reply-form">
          <input type="hidden" name="topic_slug" value={slug} />
          <textarea
            name="content"
            rows={4}
            placeholder="寫下你的想法…"
            required
            minlength={2}
          ></textarea>
          <button type="submit" class="btn-reply">回覆</button>
        </form>
      ) : (
        <div class="login-cta">
          <p>— <a href="/auth/login">登入</a>後參與討論 —</p>
        </div>
      )}
    </section>
  </main>
</Layout>

<style>
  .article-header {
    padding: 3rem 0 2rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .back-link {
    display: inline-block;
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
  }

  .article-title {
    font-size: 1.75rem;
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: 0.05em;
    color: var(--color-ink);
  }

  .article-meta {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  .author {
    color: var(--color-earth);
  }

  .article-body {
    font-size: 1rem;
    line-height: 1.9;
    color: var(--color-ink);
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--color-border);
  }

  .article-body :global(h2) {
    font-size: 1.3rem;
    font-weight: 400;
    margin: 2.5rem 0 1rem;
    letter-spacing: 0.05em;
  }

  .article-body :global(h3) {
    font-size: 1.1rem;
    font-weight: 400;
    margin: 2rem 0 0.75rem;
    letter-spacing: 0.04em;
  }

  .article-body :global(p) {
    margin: 1rem 0;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin: 0.75rem 0;
    padding-left: 1.5rem;
  }

  .article-body :global(li) {
    margin: 0.35rem 0;
  }

  .article-body :global(strong) {
    font-weight: 500;
  }

  .article-body :global(blockquote) {
    border-left: 3px solid var(--color-earth);
    margin: 1.5rem 0;
    padding: 0.5rem 1rem;
    color: var(--color-muted);
    font-style: italic;
  }

  .article-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .comments-section {
    padding: 2.5rem 0 4rem;
  }

  .comments-title {
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--color-muted);
    margin-bottom: 1.5rem;
    letter-spacing: 0.05em;
  }

  .comments-empty {
    text-align: center;
    color: var(--color-muted);
    font-size: 0.9rem;
    padding: 2rem 0;
  }

  .comment {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .comment:first-of-type {
    border-top: 1px solid var(--color-border);
  }

  .comment-meta {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
    font-size: 0.8rem;
  }

  .comment-author {
    color: var(--color-earth);
    font-weight: 500;
  }

  .comment-meta time {
    color: var(--color-muted);
  }

  .comment-body {
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--color-ink);
  }

  .comment-body :global(p) {
    margin: 0.35rem 0;
  }

  .reply-form {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .reply-form textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    background: var(--color-paper);
    color: var(--color-ink);
    font-family: inherit;
    font-size: 0.95rem;
    line-height: 1.7;
    resize: vertical;
    min-height: 100px;
  }

  .reply-form textarea:focus {
    outline: none;
    border-color: var(--color-earth);
  }

  .btn-reply {
    margin-top: 0.75rem;
    padding: 0.5rem 1.5rem;
    border: 1px solid var(--color-earth);
    border-radius: 4px;
    background: transparent;
    color: var(--color-earth);
    font-family: inherit;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
  }

  .btn-reply:hover {
    background: var(--color-earth);
    color: var(--color-paper);
  }

  .login-cta {
    text-align: center;
    padding: 2rem 0 1rem;
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .login-cta a {
    color: var(--color-earth);
  }
</style>
